# 複製成 .env.local 並填入實際值（部署到 Vercel 時填在 Environment Variables）

# Supabase → Project Settings → API → Project URL（只填網域，不要加 /rest/v1）
SUPABASE_URL=https://xxxx.supabase.co

# Supabase → Project Settings → API → service_role key
# （新版介面叫 Secret key，sb_secret_ 開頭）
# ⚠️ 這把 key 有完整讀寫權限，絕不能 commit 進 git 或放到前端程式
SUPABASE_SERVICE_ROLE_KEY=

# 管理者頁面（/admin）的登入密碼，自己取一組
ADMIN_PASSWORD=
